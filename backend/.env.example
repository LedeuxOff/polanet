# Порт сервера
PORT=3000

# Секретный ключ для JWT (измените в продакшене!)
JWT_SECRET=your-secret-key-change-in-production

# Автоматическое резервное копирование
AUTO_BACKUP=false
AUTO_BACKUP_INTERVAL=3600000
AUTO_BACKUP_MAX_COUNT=24

# Telegram Bot API
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_CHAT_ID=your-telegram-chat-id-here
TELEGRAM_BOT_USERNAME=your-bot-username-here
TELEGRAM_WEBHOOK_URL=https://your-domain.com/api/telegram/webhook

# Путь к базе данных (для продакшена)
# DATABASE_PATH=/path/to/data/polanet.db

# CORS - разрешенные домены (для продакшена)
# CORS_ORIGIN=https://admin-polanet.ru

# Логирование
LOG_LEVEL=debug
