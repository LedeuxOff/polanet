    "jsdom": "^29.1.0",
    "lint-staged": "^16.4.0",
    "postcss": "^8.4.32",
    "prettier": "^3.2.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.2.2",
    "typescript-eslint": "^8.59.1",
    "vite": "^5.0.8",
    "vitest": "^2.0.0"
